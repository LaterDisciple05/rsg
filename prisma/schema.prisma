// Prisma schema for the Rising Sun Global CMS foundation.

generator client {
  provider   = "prisma-client-js"
  output     = "../app/generated/prisma"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum Visibility {
  PUBLIC
  PRIVATE
}

enum ProjectStatus {
  PLANNED
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum InquiryStatus {
  NEW
  CONTACTED
  QUOTED
  WON
  LOST
  ARCHIVED
}

model CompanyProfile {
  id          String   @id @default(cuid())
  name        String   @default("Rising Sun Global")
  about       String?
  mission     String?
  vision      String?
  email       String?
  phone       String?
  whatsapp    String?
  linkedinUrl String?
  address     String?
  city        String?
  country     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Country {
  id        String    @id @default(cuid())
  name      String    @unique
  code      String?   @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Service {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  description String?
  icon        String?
  sortOrder   Int        @default(0)
  visibility  Visibility @default(PUBLIC)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Industry {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  description String?
  sortOrder   Int        @default(0)
  visibility  Visibility @default(PUBLIC)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Material {
  id         String     @id @default(cuid())
  title      String
  slug       String     @unique
  sortOrder  Int        @default(0)
  visibility Visibility @default(PUBLIC)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Project {
  id          String         @id @default(cuid())
  title       String
  slug        String         @unique
  description String?
  category    String?
  country     String?
  industry    String?
  featured    Boolean        @default(false)
  visibility  Visibility     @default(PRIVATE)
  status      ProjectStatus  @default(PLANNED)
  metadata    Json?
  images      ProjectImage[]
  documents   Document[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model ProjectImage {
  id        String   @id @default(cuid())
  projectId String
  url       String
  alt       String?
  sortOrder Int      @default(0)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Testimonial {
  id           String     @id @default(cuid())
  customerName String?
  companyName  String?
  message      String?
  visibility   Visibility @default(PRIVATE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model CompanyDocumentHolder {
  id          String     @id @default(cuid())
  title       String
  description String?
  visibility  Visibility @default(PRIVATE)
  documents   Document[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Document {
  id          String     @id @default(cuid())
  projectId   String?
  holderId    String?
  title       String
  fileUrl     String
  description String?
  visibility  Visibility @default(PRIVATE)
  project     Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  holder      CompanyDocumentHolder? @relation(fields: [holderId], references: [id], onDelete: SetNull)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([projectId])
  @@index([holderId])
}

model Statistic {
  id        String   @id @default(cuid())
  label     String
  value     String?
  suffix    String?
  isVisible Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Inquiry {
  id        String        @id @default(cuid())
  name      String?
  company   String?
  email     String?
  phone     String?
  country   String?
  material  String?
  quantity  String?
  message   String?
  status    InquiryStatus @default(NEW)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}
